NEBIUS_API_KEY=XXX

# Airflow compose settings
# Set AIRFLOW_UID to your host user: run `id -u` on the VM
AIRFLOW_UID=1000
AIRFLOW_GID=0
# Set DOCKER_GID to the docker socket group: run `stat -c '%g' /var/run/docker.sock` on the VM
DOCKER_GID=999
AIRFLOW_FERNET_KEY=
AIRFLOW_WEBSERVER_SECRET_KEY=change-me-to-a-long-random-string
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin

# MLflow tracking settings
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=sqlite:////mlflow/mlflow.db
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

