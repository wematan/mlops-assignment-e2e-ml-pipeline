NEBIUS_API_KEY=XXX

# Airflow compose settings
# Set AIRFLOW_UID to your host user: run `id -u` on the VM
AIRFLOW_UID=1000
AIRFLOW_GID=0
# Set DOCKER_GID to the docker socket group: run `stat -c '%g' /var/run/docker.sock` on the VM
DOCKER_GID=999
AIRFLOW_FERNET_KEY=
AIRFLOW_WEBSERVER_SECRET_KEY=change-me-to-a-long-random-string
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Execution mode: 'local' runs agent/eval as Python tasks in the scheduler;
# 'docker' runs them as real Airflow DockerOperator tasks on the runner image.
EXECUTION_MODE=local
RUNNER_IMAGE=mlops-assignment-runner:latest
# Absolute host path of this repo — REQUIRED when EXECUTION_MODE=docker so the
# DockerOperator can bind-mount runs/ into the sibling container.
HOST_PROJECT_DIR=/home/matan/mlops-assignment-e2e-ml-pipeline

# MLflow tracking settings
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=sqlite:////mlflow/mlflow.db
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# Object storage — local MinIO (S3-compatible). Leave S3_BUCKET empty to skip upload.
S3_BUCKET=mlops-runs
S3_PREFIX=runs
S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# MinIO server credentials (must match AWS_* above)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

